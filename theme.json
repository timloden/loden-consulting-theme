{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"custom": true,
			"customDuotone": true,
			"customGradient": true,
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#2563eb",
					"name": "Primary",
					"slug": "primary"
				},
				{
					"color": "#1d4ed8",
					"name": "Primary Dark",
					"slug": "primary-dark"
				},
				{
					"color": "#64748b",
					"name": "Secondary",
					"slug": "secondary"
				},
				{
					"color": "#f59e0b",
					"name": "Accent",
					"slug": "accent"
				},
				{
					"color": "#ffffff",
					"name": "White",
					"slug": "white"
				},
				{
					"color": "#f9fafb",
					"name": "Gray 50",
					"slug": "gray-50"
				},
				{
					"color": "#f3f4f6",
					"name": "Gray 100",
					"slug": "gray-100"
				},
				{
					"color": "#e5e7eb",
					"name": "Gray 200",
					"slug": "gray-200"
				},
				{
					"color": "#6b7280",
					"name": "Gray 500",
					"slug": "gray-500"
				},
				{
					"color": "#374151",
					"name": "Gray 700",
					"slug": "gray-700"
				},
				{
					"color": "#111827",
					"name": "Gray 900",
					"slug": "gray-900"
				},
				{
					"color": "#000000",
					"name": "Black",
					"slug": "black"
				}
			]
		},
		"layout": {
			"contentSize": "768px",
			"wideSize": "1280px"
		},
		"spacing": {
			"spacingScale": {
				"steps": 0
			},
			"spacingSizes": [
				{
					"name": "1",
					"size": "0.25rem",
					"slug": "10"
				},
				{
					"name": "2",
					"size": "0.5rem",
					"slug": "20"
				},
				{
					"name": "3",
					"size": "0.75rem",
					"slug": "30"
				},
				{
					"name": "4",
					"size": "1rem",
					"slug": "40"
				},
				{
					"name": "5",
					"size": "1.25rem",
					"slug": "50"
				},
				{
					"name": "6",
					"size": "1.5rem",
					"slug": "60"
				},
				{
					"name": "8",
					"size": "2rem",
					"slug": "80"
				},
				{
					"name": "10",
					"size": "2.5rem",
					"slug": "100"
				},
				{
					"name": "12",
					"size": "3rem",
					"slug": "120"
				},
				{
					"name": "16",
					"size": "4rem",
					"slug": "160"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"customFontSize": true,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "ui-sans-serif, system-ui, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\", \"Noto Color Emoji\"",
					"name": "Sans Serif",
					"slug": "sans"
				},
				{
					"fontFamily": "ui-serif, Georgia, Cambria, \"Times New Roman\", Times, serif",
					"name": "Serif",
					"slug": "serif"
				},
				{
					"fontFamily": "ui-monospace, SFMono-Regular, \"SF Mono\", Menlo, Consolas, \"Liberation Mono\", monospace",
					"name": "Monospace",
					"slug": "mono"
				}
			],
			"fontSizes": [
				{
					"fluid": false,
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"fluid": false,
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "1.25rem",
						"min": "1.125rem"
					},
					"name": "Large",
					"size": "1.25rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "1.5rem",
						"min": "1.25rem"
					},
					"name": "Extra Large",
					"size": "1.5rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "2.25rem",
						"min": "1.75rem"
					},
					"name": "2XL",
					"size": "2.25rem",
					"slug": "xx-large"
				},
				{
					"fluid": {
						"max": "3rem",
						"min": "2.25rem"
					},
					"name": "3XL",
					"size": "3rem",
					"slug": "xxx-large"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"core/button": {
				"border": {
					"radius": "0.375rem"
				},
				"spacing": {
					"padding": {
						"bottom": "0.625rem",
						"left": "1.25rem",
						"right": "1.25rem",
						"top": "0.625rem"
					}
				}
			},
			"core/code": {
				"border": {
					"radius": "0.375rem"
				},
				"color": {
					"background": "var(--wp--preset--color--gray-100)",
					"text": "var(--wp--preset--color--gray-900)"
				},
				"spacing": {
					"padding": {
						"bottom": "1rem",
						"left": "1rem",
						"right": "1rem",
						"top": "1rem"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xxx-large)",
					"fontWeight": "700"
				}
			},
			"core/quote": {
				"border": {
					"left": {
						"color": "var(--wp--preset--color--primary)",
						"style": "solid",
						"width": "4px"
					}
				},
				"spacing": {
					"padding": {
						"left": "1.5rem"
					}
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--gray-900)"
		},
		"elements": {
			"button": {
				":active": {
					"color": {
						"background": "var(--wp--preset--color--primary-dark)"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary-dark)"
					}
				},
				"border": {
					"radius": "0.375rem"
				},
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--white)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xxx-large)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"fontWeight": "700",
					"lineHeight": "1.25"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "600",
					"lineHeight": "1.3"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			},
			"link": {
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary-dark)"
					},
					"typography": {
						"textDecoration": "underline"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"textDecoration": "none"
				}
			}
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"left": "var(--wp--preset--spacing--40)",
				"right": "var(--wp--preset--spacing--40)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	]
}
